<head>
  <meta charset="utf-8" />
  <meta content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" name="viewport" />
  <title>
    <% if (page.title){ %>
    <%= page.title %> 丨
    <% } %>

    <%= theme.title || config.title %>
  </title>

  <% if (theme.favicon){ %>
  <link rel="shortcut icon" href="<%- relative_url(page.path, theme.favicon.replace(/^\//, '')) %>">
  <% } %>

  <% if (is_post()){ %>
  <link rel="preconnect" href="https://cdn.jsdelivr.net">
  <link
    id="theme"
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.9.0/styles/atom-one-light.min.css"
    data-cdn-light="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.9.0/styles/atom-one-light.min.css"
    data-cdn-dark="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.9.0/styles/atom-one-dark.min.css"
    data-local-light="<%- relative_url(page.path, 'vendor/highlight/styles/atom-one-light.min.css') %>"
    data-local-dark="<%- relative_url(page.path, 'vendor/highlight/styles/atom-one-dark.min.css') %>"
    onerror="this.onerror=null;this.href=this.dataset.localLight"
  >
  <script
    src="https://cdn.jsdelivr.net/npm/@highlightjs/cdn-assets@11.9.0/highlight.min.js"
    onload="window.highlightCodeBlocks&&window.highlightCodeBlocks()"
    onerror="this.onerror=null;this.src='<%- relative_url(page.path, 'vendor/highlight/highlight.min.js') %>'"
  ></script>
  <% } %>

  <% if (is_post() && page.mathjax){ %>
  <script>
    window.MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']]
      },
      svg: {
        fontCache: 'global'
      }
    };
  </script>
  <script
    async
    src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-svg.js"
    onerror="this.onerror=null;this.src='<%- relative_url(page.path, 'vendor/mathjax/es5/tex-svg.js') %>'"
  ></script>
  <% } %>

  <link rel="stylesheet" href="<%- relative_url(page.path, 'css/root.css') %>">
  <link rel="stylesheet" href="<%- relative_url(page.path, 'css/style.css') %>">
  <link rel="stylesheet" href="<%- relative_url(page.path, 'css/post.css') %>">
</head>
